# Copie este arquivo para ".env.local" e preencha os valores.
# ".env.local" nunca é commitado no git (veja .gitignore).

# --- Painel admin (/admin) ---
# Senha usada para entrar em /admin/login.
ADMIN_PASSWORD=

# Segredo aleatório usado para assinar o cookie de sessão do admin.
# Gere um valor forte, por exemplo com: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# --- Agenda via Google Calendar (opcional) ---
# Sem essa variável, a agenda usa o armazenamento local editado pelo /admin.
# Como obter: no Google Calendar, vá em Configurações da agenda desejada >
# "Integrar agenda" > copie o "Endereço secreto no formato iCal".
# Convenção dos eventos: título = cidade (ex. "Belo Horizonte - MG"),
# local (opcional) = nome da turnê, descrição (opcional) = link de ingressos.
GOOGLE_CALENDAR_ICS_URL=

# --- Números da seção "Sobre" via Google Sheets (opcional) ---
# Sem essa variável, os números usam o armazenamento local editado pelo /admin.
# Como obter: crie uma planilha com uma linha por número (rótulo, valor), ex.:
#   Instagram,70200
#   Facebook,67000
#   Anos,20
# Depois: Arquivo > Compartilhar > Publicar na Web > escolha a aba > formato CSV > Publicar.
GOOGLE_SHEETS_STATS_URL=

